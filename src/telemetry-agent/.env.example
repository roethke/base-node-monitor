# Base Telemetry Agent Configuration
# Copy this file to .env and configure for your node

# Required: Your Base node's RPC endpoint
NODE_RPC_URL=http://localhost:8545

# Required: Telemetry collection server
TELEMETRY_ENDPOINT=https://telemetry.base.org/api/telemetry/report

# Required: Network (mainnet or sepolia)
NETWORK=mainnet

# Optional: Give your node a name (appears on public dashboard)
# Leave empty for anonymous participation
NODE_NAME=

# Optional: Report interval in seconds (default: 21600 = 6 hours)
REPORT_INTERVAL=21600

# Optional: Enable verbose logging (default: false)
VERBOSE=false
